---
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await Astro.glob('./blog/*.md');
const posts = allPosts.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---
<BaseLayout title="VoltStream Hub" description="High voltage streaming hub">
  <section class="hero-neon">
    <h1>VoltStream Hub</h1>
    <p>High voltage streaming hub</p>
  </section>
  <section class="cards-grid">
    {posts.slice(0, 12).map(post => (
      <article class="neon-card">
        {post.frontmatter.image && (
          <img src={post.frontmatter.image} alt={post.frontmatter.title} loading="lazy" />
        )}
        <div class="card-content">
          <div class="card-meta">
            <time>{new Date(post.frontmatter.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
            {post.frontmatter.tags?.slice(0, 2).map(tag => <span class="tag">{tag}</span>)}
          </div>
          <h3><a href={post.url}>{post.frontmatter.title}</a></h3>
          <p>{post.frontmatter.description?.slice(0, 120)}</p>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
